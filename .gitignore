# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
ENV/
.python-version

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Jupyter Notebook
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
profile_default/
ipython_config.py

# Environment / secrets
.env
.env.*
*.local
# ...but keep committed example env files
!.env.example
!**/.env.example

# Testing / coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# ML models & training artifacts
# Note: best_model.keras is already tracked (committed earlier) and stays
# tracked despite the *.keras rule; this only stops NEW model/checkpoint
# files from being added by accident.
*.keras
*.h5
*.hdf5
*.ckpt
*.pt
*.pth
*.onnx
*.pb
*.tflite
checkpoints/
logs/
runs/
wandb/
mlruns/

# Datasets & large audio artifacts
data/
datasets/
*.wav
*.mp3
*.flac
*.ogg
*.npy
*.npz
# ...but keep the bundled demo sample clips the web app ships with
!web/public/samples/*.wav

# Scratch dir used to build the sample clips (huge GTZAN tarball, etc.)
_samples_build/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
