# Base URL of the AudioMind serving API. NOTE: NEXT_PUBLIC_* variables are
# inlined at BUILD time, so set this before `next build` / in your Vercel
# project's Environment Variables, not at runtime.
#
# Local dev:  http://localhost:8000  (the default if unset)
# Production: https://<your-api-host>   e.g. https://audiomind-api.onrender.com
NEXT_PUBLIC_API_BASE=http://localhost:8000
